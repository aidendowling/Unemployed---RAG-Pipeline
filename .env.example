# Copy this file to .env and fill in your local values.
# Keep .env out of version control.

# OpenRouter / generation settings
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ingestion settings
RAW_DATA_DIR=data/raw
DUCKDB_PATH=data/processed/unemployed_rag.duckdb

# Retrieval/indexing settings
INDEX_DIR=data/indexes
CHROMA_COLLECTION_NAME=labor_market
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional app metadata
APP_NAME=Unemployed RAG Pipeline
LOG_LEVEL=INFO
